    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/update-notifier": "^6.0.8",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
